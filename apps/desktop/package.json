{
  "name": "@unipet/desktop",
  "version": "0.1.5",
  "private": true,
  "type": "module",
  "main": "dist-electron/main.js",
  "scripts": {
    "build:electron": "tsc -p tsconfig.electron.json",
    "dev": "tsc -p tsconfig.electron.json && node scripts/dev.mjs",
    "build": "tsc -p tsconfig.electron.json && vue-tsc --noEmit && vite build",
    "build:package": "tsc -p tsconfig.electron.json && vue-tsc --noEmit && vite build && electron-builder",
    "build:ci": "tsc -p tsconfig.electron.json && vue-tsc --noEmit && vite build && electron-builder --publish never",
    "icons": "node scripts/generate-icons.mjs",
    "typecheck": "vue-tsc --noEmit",
    "test:e2e": "tsc -p tsconfig.electron.json && vite build && playwright test",
    "test:e2e:fast": "playwright test",
    "start": "electron ."
  },
  "dependencies": {
    "@unipet/adapters": "workspace:*",
    "@unipet/core": "workspace:*",
    "@unipet/renderers": "workspace:*",
    "@unipet/themes": "workspace:*",
    "electron-updater": "^6.3.0",
    "pinia": "^3.0.0",
    "vue": "^3.5.0",
    "vue-router": "^5.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.0",
    "@types/node": "^25.0.0",
    "@vitejs/plugin-vue": "^6.0.0",
    "electron": "^42.0.0",
    "electron-builder": "^26.0.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.0",
    "vue-tsc": "^3.0.0"
  },
  "build": {
    "appId": "dev.unipet.desktop",
    "productName": "UniPet",
    "publish": {
      "provider": "github",
      "owner": "qaz154",
      "repo": "unipet"
    },
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "electron/preload.cjs",
      "public/**/*"
    ],
    "win": {
      "target": "nsis",
      "icon": "public/icon.ico"
    },
    "mac": {
      "target": "dmg",
      "icon": "public/icon.icns"
    },
    "linux": {
      "target": "AppImage",
      "icon": "public/icon.png"
    }
  }
}
