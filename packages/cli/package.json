{
  "name": "@unipet/cli",
  "version": "0.1.9",
  "type": "module",
  "bin": {
    "unipet": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@unipet/core": "workspace:*",
    "@unipet/mcp-server": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^25.0.0",
    "typescript": "^6.0.3",
    "vitest": "^4.0.0"
  },
  "files": [
    "dist"
  ],
  "keywords": ["desktop-pet", "ai-agent", "mcp", "claude-code", "electron"],
  "repository": {
    "type": "git",
    "url": "https://github.com/qaz154/unipet.git"
  },
  "license": "MIT"
}
