{
  "name": "@unipet/mcp-server",
  "version": "0.1.4",
  "description": "MCP server for UniPet — control your desktop pet from any MCP-capable AI agent",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/qaz154/unipet.git",
    "directory": "packages/mcp-server"
  },
  "files": ["dist"],
  "keywords": ["desktop-pet", "mcp", "model-context-protocol", "ai-agent"],
  "bin": {
    "unipet-mcp": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "@unipet/core": "workspace:*",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "typescript": "^6.0.3",
    "vitest": "^3.2.0",
    "@types/node": "^22.0.0"
  }
}
