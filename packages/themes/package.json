{
  "name": "@unipet/themes",
  "version": "0.1.4",
  "description": "Theme schema, loader, validation, and SVG sanitizer for UniPet",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/qaz154/unipet.git",
    "directory": "packages/themes"
  },
  "files": ["dist"],
  "keywords": ["desktop-pet", "theme", "pixel-art", "svg"],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    },
    "./file-utils": {
      "types": "./dist/file-utils.d.ts",
      "import": "./dist/file-utils.js",
      "require": "./dist/file-utils.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@unipet/core": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^25.0.0",
    "typescript": "^6.0.3",
    "vitest": "^4.0.0"
  }
}
